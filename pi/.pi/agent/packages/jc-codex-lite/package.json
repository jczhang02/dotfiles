{
  "name": "jc-codex-lite",
  "version": "0.1.0",
  "description": "Local minimal Codex patch/image tools for Pi",
  "type": "module",
  "private": true,
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "codex",
    "apply-patch",
    "imagegen"
  ],
  "license": "MIT",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "bin": {
    "apply_patch": "./bin/apply_patch",
    "view_image": "./bin/view_image",
    "imagegen": "./bin/imagegen"
  },
  "scripts": {
    "build:binaries": "node scripts/build-binaries.mjs",
    "build:path-tool": "node scripts/build-path-tool-binary.mjs",
    "verify:binaries": "node scripts/verify-binaries.mjs"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.rs",
    "src/tools/**/Cargo.toml",
    "src/tools/Cargo.lock",
    "src/tools/**/bin/**",
    "bin/apply_patch",
    "bin/view_image",
    "bin/imagegen",
    "README.md",
    "PROVENANCE.md",
    "LICENSE",
    "scripts/*.mjs"
  ]
}
