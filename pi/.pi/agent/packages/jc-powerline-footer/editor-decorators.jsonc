{
  // Built into jc-powerline-footer's editor render path, so it does not fight setEditorComponent.
  "enabled": true,

  // Built-in decorators are always available when enabled:
  // - /skill:<name> => rainbow
  // - /command => accent (absolute paths like /tmp are skipped)
  // - workflow, workflows, workflow:<name>, workflows:<name> => rainbow

  // Extra prefix tokens. Each value styles the whole non-whitespace token after it.
  // Legacy example: "skills:" matches "skills:review" if you still want that custom hint style.
  "tokens": [
    // "skills:"
  ],

  // Literal strings/chars to color exactly.
  "literals": [
    // "TODO"
  ],

  // Alias for literal strings/chars.
  "characters": [
    // "@"
  ],

  // Extra rules. style: "rainbow", Pi theme color name ("accent", "warning"), or "#RRGGBB".
  "rules": [
    // { "type": "prefix", "value": "tools:", "style": "rainbow" },
    // { "type": "literal", "value": "TODO", "style": "warning" },
    // { "type": "regex", "value": "\\b(goal|agent):[^\\s]+", "style": "#d787af" }
  ]
}
