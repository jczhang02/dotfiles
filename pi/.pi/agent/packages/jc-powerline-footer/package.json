{
  "name": "jc-powerline-footer",
  "version": "0.6.1-jc.8",
  "description": "JC local lightweight Pi UI plugin for statusline, keyword highlighting, action vibes, welcome header, and inline slash.",
  "type": "module",
  "scripts": {
    "test": "bash tests/run-tests.sh",
    "typecheck": "bun --check *.ts inline-slash/*.ts tests/*.ts",
    "verify": "bun run typecheck && bun run test"
  },
  "files": [
    "*.ts",
    "*.md",
    "*.json",
    "*.jsonc",
    "!progress.md",
    "inline-slash/**/*.ts",
    "!tests/**"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "coding-agent",
    "powerline",
    "status-bar",
    "extension"
  ],
  "author": "JC Zhang",
  "license": "MIT",
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.79.0 <0.80.0",
    "@earendil-works/pi-coding-agent": ">=0.79.0 <0.80.0",
    "@earendil-works/pi-tui": ">=0.79.0 <0.80.0"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": ">=0.79.0 <0.80.0",
    "@earendil-works/pi-coding-agent": ">=0.79.0 <0.80.0",
    "@earendil-works/pi-tui": ">=0.79.0 <0.80.0"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "private": true,
  "jcFork": {
    "upstream": "pi-powerline-footer",
    "upstreamVersion": "0.6.1",
    "forkedFrom": "/home/jc/.pi/agent/npm/node_modules/pi-powerline-footer"
  }
}
