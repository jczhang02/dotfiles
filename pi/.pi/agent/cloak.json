{
  "enabled": true,
  "mask": "****",
  "rules": [
    {
      "filePattern": [
        "**/*.env",
        "**/*.env.*",
        "**/*.vars",
        "**/*.vars.*"
      ],
      "patterns": [
        {
          "pattern": "^(\\s*(?:[A-Za-z_][A-Za-z0-9_]*)(?:KEY|TOKEN|SECRET|PASSWORD|PASS|AUTH|CREDENTIAL|COOKIE|SESSION|BEARER|PRIVATE|CLIENT_SECRET)[A-Za-z0-9_]*\\s*=\\s*)(.+)$",
          "flags": "im",
          "replace": "$1$MASK"
        }
      ]
    },
    {
      "filePattern": [
        "**/*.json",
        "**/*.jsonc",
        "**/*.jsonl",
        "**/*.toml",
        "**/*.yaml",
        "**/*.yml",
        "**/auth.json",
        "**/web-search.json",
        "**/mcp.json"
      ],
      "patterns": [
        {
          "pattern": "(\"(?:[A-Za-z0-9_-]*(?:api[_-]?key|token|secret|password|client[_-]?secret|id[_-]?token|session[_-]?token|authorization|bearer[_-]?token|bearer[_-]?token[_-]?env)|access|refresh)\"\\s*:\\s*\")[^\"]+(\")",
          "flags": "i",
          "replace": "$1$MASK$2"
        },
        {
          "pattern": "((?:api[_-]?key|token|secret|password|client_secret|authorization)\\s*=\\s*)[^\\s#]+",
          "flags": "i",
          "replace": "$1$MASK"
        }
      ]
    }
  ]
}
