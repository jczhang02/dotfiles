{
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "xhigh",
  "thinkingBudgets": {
    "minimal": 1024,
    "low": 2048,
    "medium": 8192,
    "high": 16384,
    "xhigh": 24576
  },
  "transport": "sse",
  "websocketConnectTimeoutMs": 120000,
  "httpIdleTimeoutMs": 120000,
  "theme": "catppuccin-latte",
  "quietStartup": true,
  "collapseChangelog": true,
  "editorPaddingX": 1,
  "showHardwareCursor": true,
  "hideThinkingBlock": false,
  "autocompleteMaxVisible": 8,
  "enableInstallTelemetry": false,
  "terminal": {
    "showImages": true,
    "imageWidthCells": 60
  },
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "provider": {
      "maxRetries": 0
    }
  },
  "enabledModels": [
    "openai-codex/*"
  ],
  "enableSkillCommands": true,
  "skills": [
    "~/.agents/skills"
  ],
  "extensions": [
    "extensions",
    "/home/jc/.pi/agent/npm/node_modules/@pi-unipi/notify/index.ts"
  ],
  "packages": [
    "npm:pi-mcp-adapter",
    "npm:pi-rtk-optimizer",
    "npm:@juicesharp/rpiv-ask-user-question",
    "npm:pi-caveman",
    "npm:pi-context-usage",
    "git:github.com/hasit/pi-community-themes",
    "npm:@juicesharp/rpiv-todo",
    "https://github.com/davebcn87/pi-autoresearch",
    "npm:pi-worktree",
    "npm:pi-powerline-footer",
    "npm:@pi-unipi/notify",
    "npm:pi-dynamic-workflows",
    "npm:@byteowlz/pi-auto-rename",
    "npm:pi-rewind",
    "npm:pi-subagents",
    "npm:pi-codex-goal",
    "npm:@complexthings/pi-dynamic-context-pruning",
    "npm:@ff-labs/pi-fff",
    "npm:pi-loadout",
    "https://github.com/monotykamary/pi-tps",
    "npm:nowledge-mem-pi",
    "npm:@howaboua/pi-codex-conversion",
    "npm:pi-context-prune",
    "npm:pi-smart-fetch"
  ],
  "lastChangelogVersion": "0.79.1",
  "powerline": {
    "preset": "default",
    "fixedEditor": false
  },
  "observational-memory": {
    "passive": true
  }
}
