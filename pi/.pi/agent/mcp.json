{
  "settings": {
    "toolPrefix": "server",
    "idleTimeout": 10,
    "directTools": false
  },
  "mcpServers": {
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "lifecycle": "lazy",
      "directTools": false
    },
    "zotero": {
      "command": "/home/jc/.local/bin/zotero-mcp",
      "env": {
        "ZOTERO_LOCAL": "true"
      },
      "lifecycle": "lazy",
      "directTools": false
    },
    "open-design": {
      "command": "/usr/bin/open-design-mcp",
      "args": [],
      "env": {
        "OD_DATA_DIR": "/home/jc/.local/share/open-design/namespaces/default/data",
        "OD_SIDECAR_IPC_PATH": "/tmp/open-design/ipc/default/daemon.sock"
      },
      "lifecycle": "lazy",
      "directTools": false
    }
  }
}
