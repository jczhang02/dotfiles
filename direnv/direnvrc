    #    layout mamba_uv <your_environment_name>

    MAMBA_ROOT_PREFIX="${HOME}/.conda" # Make sure this points to path of your micromamba install
    MAMBA_EXE="/usr/bin/mamba"         # Should be pointing to the micromamba binary
    # evaluating the Shell in use, e.g. bash/zsh/fish
