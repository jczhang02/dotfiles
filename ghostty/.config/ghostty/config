# Theme: auto dark/light switching
window-theme = system
theme = light:catppuccin-latte.conf,dark:catppuccin-mocha.conf

# Font
font-family = Iosevka Nerd Font Mono
font-family = Symbols Nerd Font
font-family = LXGW WenKai Mono
font-size = 12

# Disable ligatures
font-feature = -calt
font-feature = -clig
font-feature = -liga

# Window
window-height = 50
window-width = 150
window-padding-x = 0
window-padding-y = 0
window-decoration = auto
window-show-tab-bar = never
background-opacity = 1
confirm-close-surface = false

quit-after-last-window-closed = false



# GTK integration (closest to WezTerm's INTEGRATED_BUTTONS|RESIZE)

# Input
mouse-hide-while-typing = false

# Misc
auto-update = off

# Keybindings
keybind = ctrl+enter=text:\x1b[13;5u
keybind = shift+enter=text:\x1b[13;2u
keybind = ctrl+shift+enter=text:\x1b[13;6u
keybind = ctrl+backspace=text:\x17
