# set-hook -ga after-select-pane  "run-shell -b '~/.config/tmux/plugins/tmux-window-name/scripts/rename_session_windows.py'"
# set-hook -ga after-resize-pane  "run-shell -b '~/.config/tmux/plugins/tmux-window-name/scripts/rename_session_windows.py'"

# semantic auto-renaming for pi/claude + dev tools
# Local dev plugin is TPM-compatible, but sourced directly so TPM does not try to clone it.
run-shell -b '/home/jc/dev/tmux-autoname/tmux-autoname.tmux'

# === 切 pane/window/session 时强制 fcitx5 回英文 ===
# tmux 内部焦点事件不触发 wayland focus-in, fcitx5 不会自动 reset.
# 主动调 fcitx5-remote -c (deactivate).
set-hook -ga after-select-pane    "run-shell -b 'command -v fcitx5-remote >/dev/null && fcitx5-remote -c'"
set-hook -ga after-select-window  "run-shell -b 'command -v fcitx5-remote >/dev/null && fcitx5-remote -c'"
set-hook -ga client-session-changed "run-shell -b 'command -v fcitx5-remote >/dev/null && fcitx5-remote -c'"

# system clipboard yank
set -g @plugin 'tmux-plugins/tmux-yank'
set -g @yank_selection_mouse 'tmux'  # OSC52 转发, 不再 fork wl-copy

# Ctrl-h/j/k/l moves across vim splits + tmux panes
set -g @plugin 'christoomey/vim-tmux-navigator'

# prefix u → fuzzy pick URL from current pane, open in browser
set -g @plugin 'wfxr/tmux-fzf-url'

# prefix F → tmux-fzf menu (session/window/pane/command/keybinding/clipboard/process)
# prefix b → 直接进 clipboard (paste-buffer 选择器)
set -g @plugin 'sainnhe/tmux-fzf'
TMUX_FZF_LAUNCH_KEY="F"
unbind b
bind b run-shell -b "~/.config/tmux/plugins/tmux-fzf/scripts/clipboard.sh buffer"

# M-p (no-prefix) → tmux-palette: Raycast-like command palette (Bun-based)
# 默认 @palette-key=C-Space 会撞 tmux prefix, 故改 M-p
set -g @plugin 'eduwass/tmux-palette'
set -g @palette-key 'M-p'

# layout-only persistence across reboot
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'
set -g @resurrect-capture-pane-contents 'on'
set -g @continuum-save-interval '15'
set -g @continuum-restore 'on'



set -g allow-passthrough on
# -- custom variables ----------------------------------------------------------

# to define a custom #{foo} variable, define a POSIX shell function between the
# '# EOF' and the '# "$@"' lines. Please note that the opening brace { character
# must be on the same line as the function name otherwise the parse won't detect
# it.
#
# then, use #{foo} in e.g. the 'tmux_conf_theme_status_left' or the
# 'tmux_conf_theme_status_right' variables.

